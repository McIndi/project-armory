---
# Catch-all HTTP→HTTPS redirect for the redirect-only ingress policy. Owned
# by the gateway (edge policy), attached to the plain HTTP listener only.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ envoy_gateway_gateway_name }}-https-redirect
  namespace: {{ envoy_gateway_namespace }}
spec:
  parentRefs:
    - name: {{ envoy_gateway_gateway_name }}
      sectionName: http
  rules:
    - filters:
        - type: RequestRedirect
          requestRedirect:
            scheme: https
            statusCode: 301
