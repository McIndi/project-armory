---
# Explicit GatewayClass: declares Envoy Gateway as the owning controller and
# binds the class to the Armory EnvoyProxy data-plane configuration.
apiVersion: gateway.networking.k8s.io/v1
kind: GatewayClass
metadata:
  name: {{ envoy_gateway_class_name }}
spec:
  controllerName: {{ envoy_gateway_controller_name }}
  parametersRef:
    group: gateway.envoyproxy.io
    kind: EnvoyProxy
    name: {{ envoy_gateway_envoyproxy_name }}
    namespace: {{ envoy_gateway_namespace }}
