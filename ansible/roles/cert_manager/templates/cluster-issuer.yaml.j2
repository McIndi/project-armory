---
{% for issuer in certmanager_openbao_cluster_issuers %}
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ issuer.name }}
spec:
  vault:
    server: {{ certmanager_openbao_cluster_addr }}
    serverName: {{ certmanager_openbao_tls_server_name }}
    caBundleSecretRef:
      name: {{ certmanager_openbao_ca_secret_name }}
      key: ca.crt
    path: {{ issuer.mount }}/sign/{{ issuer.role }}
    auth:
      kubernetes:
        role: {{ certmanager_openbao_k8s_role }}
        mountPath: /v1/auth/kubernetes
        serviceAccountRef:
          name: {{ certmanager_release_name }}
---
{% endfor %}
