# Managed by Ansible — do not edit manually
{% if k3s_disable | length > 0 %}
disable:
{% for item in k3s_disable %}
  - {{ item }}
{% endfor %}
{% endif %}
{% if k3s_secrets_encryption %}
secrets-encryption: true
{% endif %}
{% if (k3s_oidc_enabled | default(false) | bool) and (k3s_oidc_ca_configured | default(false) | bool) %}
kube-apiserver-arg:
  - "oidc-issuer-url={{ k3s_oidc_issuer_url }}"
  - "oidc-client-id={{ k3s_oidc_client_id }}"
  - "oidc-username-claim={{ k3s_oidc_username_claim }}"
  - "oidc-groups-claim={{ k3s_oidc_groups_claim }}"
  - "oidc-ca-file={{ k3s_oidc_ca_file }}"
{% endif %}
