---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: agentstack-ui
  namespace: {{ beeai_tofu_namespace }}
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/service-upstream: "true"
    nginx.ingress.kubernetes.io/proxy-buffer-size: "{{ beeai_ingress_proxy_buffer_size }}"
    nginx.ingress.kubernetes.io/proxy-buffers-number: "{{ beeai_ingress_proxy_buffers_number }}"
    nginx.ingress.kubernetes.io/proxy-busy-buffers-size: "{{ beeai_ingress_proxy_busy_buffers_size }}"
spec:
  ingressClassName: {{ beeai_ingress_class }}
  tls:
    - hosts:
        - {{ beeai_public_base_url | urlsplit('hostname') }}
      secretName: {{ beeai_ingress_tls_secret }}
  rules:
    - host: {{ beeai_public_base_url | urlsplit('hostname') }}
      http:
        paths:
          # Keycloak paths — more specific, matched before the catch-all
          - path: /realms
            pathType: Prefix
            backend:
              service:
                name: {{ beeai_keycloak_service_name }}
                port:
                  number: {{ beeai_keycloak_service_port }}
          - path: /resources
            pathType: Prefix
            backend:
              service:
                name: {{ beeai_keycloak_service_name }}
                port:
                  number: {{ beeai_keycloak_service_port }}
          # All other traffic (/, /api/*, /api/auth/*, etc.) goes to the UI.
          # The UI Next.js server hosts an /api/[...path] proxy that injects
          # the OIDC access token as a Bearer header before forwarding to the
          # API service over the internal cluster network.
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{ beeai_ui_service_name }}
                port:
                  number: {{ beeai_ui_service_port }}
