# Managed by Ansible — do not edit manually
global:
  tlsDisable: {{ (not (openbao_tls_enabled | bool)) | lower }}

server:
  standalone:
    enabled: true
    config: |
      ui = false

      listener "tcp" {
        tls_disable     = {{ 0 if (openbao_tls_enabled | bool) else 1 }}
        address         = "[::]:8200"
        cluster_address = "[::]:8201"
{% if openbao_tls_enabled | bool %}
        tls_cert_file   = "{{ openbao_tls_cert_file_path }}"
        tls_key_file    = "{{ openbao_tls_key_file_path }}"
{% endif %}
      }

      storage "file" {
        path = "/openbao/data"
      }

  service:
    enabled: true
    type: NodePort
    publishNotReadyAddresses: true
    port: 8200
    targetPort: 8200
    nodePort: {{ openbao_node_port }}

  dataStorage:
    enabled: true
    size: 1Gi

  readinessProbe:
    enabled: true
    periodSeconds: {{ openbao_readiness_period_seconds }}
    timeoutSeconds: {{ openbao_readiness_timeout_seconds }}
    failureThreshold: {{ openbao_readiness_failure_threshold }}

  serviceAccount:
    create: true
    name: openbao

{% if openbao_tls_enabled | bool %}
  volumes:
    - name: openbao-server-tls
      secret:
        secretName: {{ openbao_tls_secret_name }}

  volumeMounts:
    - name: openbao-server-tls
      mountPath: {{ openbao_tls_cert_mount_path }}
      readOnly: true
{% endif %}

ui:
  enabled: false

injector:
  enabled: false
