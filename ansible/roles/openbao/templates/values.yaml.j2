# Managed by Ansible — do not edit manually
global:
  tlsDisable: {{ (not (openbao_tls_enabled | bool)) | lower }}

server:
  standalone:
    enabled: true
    config: |
      ui = {{ openbao_ui_enabled | bool | lower }}

      listener "tcp" {
        tls_disable     = {{ 0 if (openbao_tls_enabled | bool) else 1 }}
        address         = "[::]:8200"
        cluster_address = "[::]:8201"
{% if openbao_tls_enabled | bool %}
        tls_cert_file   = "{{ openbao_tls_cert_file_path }}"
        tls_key_file    = "{{ openbao_tls_key_file_path }}"
{% endif %}
      }

      storage "file" {
        path = "/openbao/data"
      }
{% if openbao_audit_enabled | bool %}

      audit "file" "{{ openbao_audit_device_name }}" {
        options {
          file_path = "{{ openbao_audit_log_path }}"
          mode = "0600"
        }
      }
{% endif %}

  service:
    enabled: true
    type: ClusterIP
    publishNotReadyAddresses: true
    port: 8200
    targetPort: 8200

  resources:
    requests:
      cpu: {{ openbao_resources_requests_cpu }}
      memory: {{ openbao_resources_requests_memory }}
    limits:
      cpu: {{ openbao_resources_limits_cpu }}
      memory: {{ openbao_resources_limits_memory }}

  dataStorage:
    enabled: true
    size: 1Gi

{% if openbao_audit_enabled | bool %}
  auditStorage:
    enabled: true
    size: {{ openbao_audit_storage_size }}
    mountPath: {{ openbao_audit_mount_path }}
{% endif %}

  readinessProbe:
    enabled: true
    periodSeconds: {{ openbao_readiness_period_seconds }}
    timeoutSeconds: {{ openbao_readiness_timeout_seconds }}
    failureThreshold: {{ openbao_readiness_failure_threshold }}

  serviceAccount:
    create: true
    name: openbao

{% if openbao_tls_enabled | bool %}
  volumes:
    - name: openbao-server-tls
      secret:
        secretName: {{ openbao_tls_secret_name }}

  volumeMounts:
    - name: openbao-server-tls
      mountPath: {{ openbao_tls_cert_mount_path }}
      readOnly: true
{% endif %}

ui:
  enabled: {{ openbao_ui_enabled | bool | lower }}

injector:
  enabled: false
