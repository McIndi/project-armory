---
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultConnection
metadata:
  name: {{ headlamp_vault_connection_name }}
  namespace: {{ headlamp_namespace }}
spec:
  address: {{ headlamp_openbao_cluster_addr }}
  tlsServerName: {{ headlamp_openbao_tls_server_name }}
  caCertSecretRef: {{ headlamp_openbao_ca_secret_name }}
  skipTLSVerify: false
