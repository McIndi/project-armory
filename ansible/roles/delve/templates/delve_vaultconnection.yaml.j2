---
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultConnection
metadata:
  name: {{ delve_vault_connection_name }}
  namespace: {{ delve_namespace }}
spec:
  address: {{ delve_openbao_cluster_addr }}
  tlsServerName: {{ delve_openbao_tls_server_name }}
  caCertSecretRef: {{ delve_openbao_ca_secret_name }}
  skipTLSVerify: false
