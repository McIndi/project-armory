---
# OpenBao audit feed shipper. Tails the OpenBao audit log (already JSON with
# HMAC'd secrets — no parser) and POSTs to Delve api/events/ with a delve-ingest
# bearer token. The audit log lives on the openbao auditStorage PVC (RWO, ns
# openbao); on single-node k3s its local-path-backed host directory is mounted
# read-only here, so the shipper stays in ns delve. Runs as root to read the
# audit file regardless of its owner. The position cursor persists on a host dir
# so a restart does not re-ingest the current log.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: delve-shipper-openbao-audit
  namespace: {{ delve_namespace }}
  labels:
    app.kubernetes.io/name: delve-shipper
    app.kubernetes.io/component: openbao-audit
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: delve-shipper
      app.kubernetes.io/component: openbao-audit
  template:
    metadata:
      labels:
        app.kubernetes.io/name: delve-shipper
        app.kubernetes.io/component: openbao-audit
    spec:
      serviceAccountName: {{ delve_pod_sa_name }}
      securityContext:
        runAsUser: 0
{% if delve_image_pull_secrets | default([]) | length > 0 %}
      imagePullSecrets:
{% for secret in delve_image_pull_secrets %}
        - name: {{ secret }}
{% endfor %}
{% endif %}
{% if (_delve_shipper_host_aliases | default([])) | length > 0 %}
      hostAliases:
{% for alias in _delve_shipper_host_aliases %}
        - ip: {{ alias.ip }}
          hostnames:
{% for hostname in alias.hostnames %}
            - {{ hostname }}
{% endfor %}
{% endfor %}
{% endif %}
      containers:
        - name: shipper
          image: "{{ delve_shipper_image_repository }}:{{ delve_shipper_image_tag }}"
          imagePullPolicy: {{ delve_shipper_image_pull_policy }}
          command: ["python", "utilities/cli/tail-files.py"]
          args:
            - "--server"
            - "{{ delve_shipper_server_url }}"
            - "--auth"
            - "bearer"
            - "--token-url"
            - "{{ delve_shipper_token_url }}"
            - "--client-id"
            - "{{ delve_ingest_client_id }}"
            - "--ca-file"
            - "{{ delve_shipper_ca_mount_path }}/{{ delve_shipper_ca_file_name }}"
            - "-i"
            - "{{ delve_shipper_openbao_index }}"
            - "-t"
            - "{{ delve_shipper_openbao_sourcetype }}"
            - "-H"
            - "openbao"
            - "-v"
            - "/openbao-audit/{{ delve_shipper_openbao_audit_filename }}"
          env:
            - name: DELVE_INGEST_CLIENT_SECRET
              valueFrom:
                secretKeyRef:
                  name: {{ delve_ingest_secret_name }}
                  key: OIDC_CLIENT_SECRET
          volumeMounts:
            - name: openbao-audit
              mountPath: /openbao-audit
              readOnly: true
            - name: shipper-data
              mountPath: /app/utilities/_data
            - name: ingest-ca
              mountPath: {{ delve_shipper_ca_mount_path }}
              readOnly: true
      volumes:
        - name: openbao-audit
          hostPath:
            path: {{ delve_shipper_openbao_host_dir }}
            type: Directory
        - name: shipper-data
          hostPath:
            path: /var/lib/delve-shippers/openbao-audit
            type: DirectoryOrCreate
        - name: ingest-ca
          secret:
            secretName: {{ delve_ingest_secret_name }}
            items:
              - key: OIDC_CA_PEM
                path: {{ delve_shipper_ca_file_name }}
