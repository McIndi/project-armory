---
apiVersion: v1
kind: Service
metadata:
  name: {{ delve_pg_service }}
  namespace: {{ delve_namespace }}
  labels:
    app.kubernetes.io/name: delve-postgres
    app.kubernetes.io/part-of: delve
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: delve-postgres
  ports:
    - name: postgres
      port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ delve_pg_service }}
  namespace: {{ delve_namespace }}
  labels:
    app.kubernetes.io/name: delve-postgres
    app.kubernetes.io/part-of: delve
spec:
  serviceName: {{ delve_pg_service }}
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: delve-postgres
  template:
    metadata:
      labels:
        app.kubernetes.io/name: delve-postgres
        app.kubernetes.io/part-of: delve
    spec:
      securityContext:
        fsGroup: 999
      containers:
        - name: postgres
          image: {{ delve_pg_image }}
          imagePullPolicy: IfNotPresent
          ports:
            - name: postgres
              containerPort: 5432
          env:
            - name: POSTGRES_DB
              value: "{{ delve_db_name }}"
            - name: POSTGRES_USER
              valueFrom:
                secretKeyRef:
                  name: {{ delve_db_secret_name }}
                  key: username
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ delve_db_secret_name }}
                  key: password
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ delve_db_username }}", "-d", "{{ delve_db_name }}"]
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 6
          livenessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ delve_db_username }}", "-d", "{{ delve_db_name }}"]
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 6
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: "1"
              memory: 512Mi
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
{% if (delve_pg_storage_class | default('') | trim) | length > 0 %}
        storageClassName: {{ delve_pg_storage_class }}
{% endif %}
        resources:
          requests:
            storage: {{ delve_pg_storage_size }}
