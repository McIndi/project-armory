---
# Bootstrap import of the `armory` realm. Import-oriented: creates the realm,
# seed admin user, and admin group. Ongoing per-client config (e.g. the Headlamp
# OIDC client and its groups claim mapper) is handled by the consuming role via
# the Keycloak admin REST API, not here.
#
# NOTE: deliberately does NOT declare `clientScopes`. Supplying that key makes
# Keycloak skip creation of its built-in client scopes (profile, email, roles,
# web-origins, acr, ...), so clients can no longer request `profile`/`email` —
# OIDC sign-in then fails with "Invalid scopes" / "Code not valid". Leave the
# built-in scopes intact and attach custom claims (groups) per-client via REST.
apiVersion: k8s.keycloak.org/v2alpha1
kind: KeycloakRealmImport
metadata:
  name: {{ keycloak_realm }}-realm
  namespace: {{ keycloak_namespace }}
spec:
  keycloakCRName: {{ keycloak_cr_name }}
  realm:
    realm: {{ keycloak_realm }}
    enabled: true
    sslRequired: external
    eventsEnabled: {{ keycloak_events_enabled | bool | string | lower }}
    eventsExpiration: {{ keycloak_events_expiration_seconds | int }}
    eventsListeners:
{% for listener in keycloak_events_listeners %}
      - {{ listener }}
{% endfor %}
    adminEventsEnabled: {{ keycloak_admin_events_enabled | bool | string | lower }}
    adminEventsDetailsEnabled: {{ keycloak_admin_events_details_enabled | bool | string | lower }}
    groups:
{% for group_name in keycloak_realm_groups %}
      - name: {{ group_name }}
{% endfor %}
    users:
      - username: {{ keycloak_realm_admin_username }}
        enabled: true
        emailVerified: true
        email: {{ keycloak_realm_admin_email }}
        firstName: {{ keycloak_realm_admin_first_name }}
        lastName: {{ keycloak_realm_admin_last_name }}
        groups:
          - /{{ keycloak_admin_group }}
        credentials:
          - type: password
            value: {{ _keycloak_realm_admin_password | to_json }}
            temporary: false
