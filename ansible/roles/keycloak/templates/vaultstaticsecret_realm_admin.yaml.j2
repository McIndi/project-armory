---
# Mirror the realm `armory` admin login (Headlamp login) from OpenBao into a k8s
# Secret for operator convenience. refreshAfter keeps it current if the OpenBao
# value is rotated. Reuses the keycloak-namespace VaultConnection/VaultAuth.
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: keycloak-realm-admin-sync
  namespace: {{ keycloak_namespace }}
spec:
  type: kv-v2
  mount: {{ keycloak_openbao_kv_mount }}
  path: {{ keycloak_openbao_realm_admin_path }}
  destination:
    name: {{ keycloak_realm_admin_secret_name }}
    create: true
  vaultAuthRef: {{ keycloak_vault_auth_name }}
  refreshAfter: 60s
