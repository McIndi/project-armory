---
apiVersion: secrets.hashicorp.com/v1beta1
kind: VaultStaticSecret
metadata:
  name: keycloak-db-sync
  namespace: {{ keycloak_namespace }}
spec:
  type: kv-v2
  mount: {{ keycloak_openbao_kv_mount }}
  path: {{ keycloak_openbao_db_path }}
  destination:
    name: {{ keycloak_db_secret_name }}
    create: true
  vaultAuthRef: {{ keycloak_vault_auth_name }}
  refreshAfter: {{ keycloak_vault_static_secret_refresh_after }}
  hmacSecretData: true
