Jun 12 2026 14:12:56 - playbooks/site.yml - Apply realm-admin rotator manifests (SA, ConfigMap, CronJob) - ansible.builtin.command - OK - {"module_args": {"cmd": "k3s kubectl apply -f -", "stdin": "---\n# Auto-rotation of the realm `armory` admin login.\n# SA (for OpenBao k8s auth) + ConfigMap (rotation script) + CronJob.\n# The job authenticates to Keycloak with a dedicated service-account client\n# (realm-management `manage-users`), NOT the master bootstrap admin.\napiVersion: v1\nkind: ServiceAccount\nmetadata:\n  name: keycloak-realm-admin-rotator\n  namespace: keycloak\n---\napiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: keycloak-realm-admin-rotate-script\n  namespace: keycloak\ndata:\n  rotate.py: |\n    import json, os, secrets, ssl, string, sys\n    import urllib.request, urllib.parse, urllib.error\n\n    def http(method, url, data=None, headers=None, cafile=None, form=False):\n        h = dict(headers or {})\n        body = None\n        if data is not None:\n            if form:\n                body = urllib.parse.urlencode(data).encode()\n                h[\"Content-Type\"] = \"application/x-www-form-urlencoded\"\n            else:\n                body = json.dumps(data).encode()\n                h.setdefault(\"Content-Type\", \"application/json\")\n        req = urllib.request.Request(url, data=body, method=method, headers=h)\n        ctx = ssl.create_default_context(cafile=cafile) if url.startswith(\"https\") else None\n        try:\n            with urllib.request.urlopen(req, context=ctx, timeout=30) as r:\n                raw = r.read()\n                return r.status, (json.loads(raw) if raw else {})\n        except urllib.error.HTTPError as e:\n            sys.stderr.write(\"HTTP %s %s %s: %r\\n\" % (e.code, method, url, e.read()[:300]))\n            raise\n\n    def env(k):\n        v = os.environ.get(k)\n        if not v:\n            sys.exit(\"missing env %s\" % k)\n        return v\n\n    addr = env(\"OPENBAO_ADDR\")\n    ca = env(\"OPENBAO_CA_FILE\")\n    mount = env(\"OPENBAO_KV_MOUNT\")\n    kc = env(\"KEYCLOAK_URL\")\n    kc_ca = env(\"KEYCLOAK_CA_FILE\")\n    realm = env(\"KEYCLOAK_REALM\")\n    username = env(\"REALM_ADMIN_USERNAME\")\n    length = int(os.environ.get(\"PASSWORD_LENGTH\", \"24\"))\n\n    jwt = open(\"/var/run/secrets/kubernetes.io/serviceaccount/token\").read().strip()\n    _, j = http(\"POST\", \"%s/v1/auth/kubernetes/login\" % addr,\n                {\"role\": env(\"OPENBAO_K8S_ROLE\"), \"jwt\": jwt}, cafile=ca)\n    bh = {\"X-Vault-Token\": j[\"auth\"][\"client_token\"]}\n\n    _, j = http(\"GET\", \"%s/v1/%s/data/%s\" % (addr, mount, env(\"OPENBAO_ROTATOR_PATH\")),\n                headers=bh, cafile=ca)\n    rot = j[\"data\"][\"data\"]\n    client_id = rot.get(\"client_id\") or env(\"ROTATOR_CLIENT_ID\")\n\n    _, j = http(\"POST\", \"%s/realms/%s/protocol/openid-connect/token\" % (kc, realm),\n                {\"grant_type\": \"client_credentials\", \"client_id\": client_id,\n              \"client_secret\": rot[\"client_secret\"]}, cafile=kc_ca, form=True)\n    kh = {\"Authorization\": \"Bearer %s\" % j[\"access_token\"]}\n\n    _, users = http(\"GET\",\n                    \"%s/admin/realms/%s/users?username=%s&exact=true\" % (kc, realm, username),\n                headers=kh, cafile=kc_ca)\n    if not users:\n        sys.exit(\"realm user '%s' not found\" % username)\n    uid = users[0][\"id\"]\n\n    alphabet = string.ascii_letters + string.digits\n    newpw = \"\".join(secrets.choice(alphabet) for _ in range(length))\n\n    http(\"PUT\", \"%s/admin/realms/%s/users/%s/reset-password\" % (kc, realm, uid),\n          {\"type\": \"password\", \"value\": newpw, \"temporary\": False}, headers=kh, cafile=kc_ca)\n    http(\"POST\", \"%s/v1/%s/data/%s\" % (addr, mount, env(\"OPENBAO_REALM_ADMIN_PATH\")),\n         {\"data\": {\"username\": username, \"password\": newpw}}, headers=bh, cafile=ca)\n    print(\"rotated realm-admin password for user '%s'\" % username)\n---\napiVersion: batch/v1\nkind: CronJob\nmetadata:\n  name: keycloak-realm-admin-rotate\n  namespace: keycloak\nspec:\n  schedule: \"0 3 1 * *\"\n  concurrencyPolicy: Forbid\n  successfulJobsHistoryLimit: 1\n  failedJobsHistoryLimit: 3\n  jobTemplate:\n    spec:\n      backoffLimit: 2\n      activeDeadlineSeconds: 300\n      template:\n        spec:\n          serviceAccountName: keycloak-realm-admin-rotator\n          restartPolicy: Never\n          securityContext:\n            runAsNonRoot: true\n            runAsUser: 1000\n            seccompProfile:\n              type: RuntimeDefault\n          containers:\n            - name: rotate\n              image: python:3.12-slim\n              imagePullPolicy: IfNotPresent\n              command: [\"python3\", \"/app/rotate.py\"]\n              securityContext:\n                allowPrivilegeEscalation: false\n                readOnlyRootFilesystem: true\n                capabilities:\n                  drop: [\"ALL\"]\n              env:\n                - name: OPENBAO_ADDR\n                  value: \"https://openbao.openbao.svc.cluster.local:8200\"\n                - name: OPENBAO_CA_FILE\n                  value: /etc/openbao-ca/ca.crt\n                - name: OPENBAO_KV_MOUNT\n                  value: \"secret\"\n                - name: OPENBAO_K8S_ROLE\n                  value: \"keycloak-realm-admin-rotator\"\n                - name: OPENBAO_ROTATOR_PATH\n                  value: \"keycloak/rotator\"\n                - name: OPENBAO_REALM_ADMIN_PATH\n                  value: \"keycloak/realm-admin\"\n                - name: KEYCLOAK_URL\n                  value: \"https://keycloak-service.keycloak.svc.cluster.local:8443\"\n                - name: KEYCLOAK_CA_FILE\n                  value: /etc/keycloak-ca/ca.crt\n                - name: KEYCLOAK_REALM\n                  value: \"armory\"\n                - name: ROTATOR_CLIENT_ID\n                  value: \"realm-admin-rotator\"\n                - name: REALM_ADMIN_USERNAME\n                  value: \"admin\"\n                - name: PASSWORD_LENGTH\n                  value: \"24\"\n              resources:\n                requests:\n                  cpu: 50m\n                  memory: 64Mi\n                limits:\n                  cpu: 250m\n                  memory: 128Mi\n              volumeMounts:\n                - name: openbao-ca\n                  mountPath: /etc/openbao-ca\n                  readOnly: true\n                - name: keycloak-ca\n                  mountPath: /etc/keycloak-ca\n                  readOnly: true\n                - name: script\n                  mountPath: /app\n                  readOnly: true\n          volumes:\n            - name: openbao-ca\n              secret:\n                secretName: openbao-ca-bundle\n            - name: keycloak-ca\n              secret:\n                secretName: openbao-ca-bundle\n            - name: script\n              configMap:\n                name: keycloak-realm-admin-rotate-script\n", "_uses_shell": false, "expand_argument_vars": true, "stdin_add_newline": true, "strip_empty_ends": true, "_raw_params": null, "argv": null, "chdir": null, "executable": null, "creates": null, "removes": null}} => {"changed": true, "stdout": "serviceaccount/keycloak-realm-admin-rotator created\nconfigmap/keycloak-realm-admin-rotate-script created\ncronjob.batch/keycloak-realm-admin-rotate created", "stderr": "", "rc": 0, "cmd": ["k3s", "kubectl", "apply", "-f", "-"], "start": "2026-06-12 14:12:55.012170", "end": "2026-06-12 14:12:56.065247", "delta": "0:00:01.053077", "msg": "", "stdout_lines": ["serviceaccount/keycloak-realm-admin-rotator created", "configmap/keycloak-realm-admin-rotate-script created", "cronjob.batch/keycloak-realm-admin-rotate created"], "stderr_lines": [], "_ansible_no_log": false} 

