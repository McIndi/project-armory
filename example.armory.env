# =============================================================================
# armory.env — Unified config for Project Armory
#
# Copy this file to armory.env and adjust values before any non-demo use.
# armory.env is gitignored and never committed.
#
# HOW THIS FILE IS USED
# ---------------------
#   rebuild.sh sources this file automatically at startup. All TF_VAR_*
#   variables are picked up by every `tofu apply` call without any -var-file
#   flag — this is Terraform/OpenTofu's built-in cross-module env mechanism.
#   ARMORY_* variables are used directly by rebuild.sh for health checks,
#   port references, and the post-build summary.
#
# CHANGING VALUES
# ---------------
#   1. Edit armory.env (not this file).
#   2. Re-run rebuild.sh — all modules and the script pick up new values.
#   3. If you change ports, also update the Vagrantfile firewall rules
#      (02-firewall provisioner) and re-run:
#        vagrant provision --provision-with 02-firewall
# =============================================================================

# =============================================================================
# NETWORK — host IP, ports, and Podman network name
# =============================================================================

# Host IP that Vault binds to and advertises. Use 0.0.0.0 to expose externally.
export ARMORY_HOST_IP="127.0.0.1"
export TF_VAR_api_addr="${ARMORY_HOST_IP}"     # vault/ module

# Vault API port (8200) and internal cluster/raft port (8201).
# 8201 is not published to the host; it is only used container-to-container.
export ARMORY_VAULT_PORT=8200
export TF_VAR_vault_port="${ARMORY_VAULT_PORT}"
export TF_VAR_vault_cluster_port=8201

# Service ports — must match Vagrantfile firewall rules for externally-exposed ports.
export ARMORY_WEBSERVER_PORT=8443
export TF_VAR_nginx_host_port="${ARMORY_WEBSERVER_PORT}"   # services/webserver/
export ARMORY_KEYCLOAK_PORT=8444
export ARMORY_AGENT_PORT=8445
export TF_VAR_agent_host_port="${ARMORY_AGENT_PORT}"       # services/agent/
export ARMORY_WAZUH_API_PORT=55000
export TF_VAR_wazuh_api_port="${ARMORY_WAZUH_API_PORT}"    # services/wazuh/
export ARMORY_WAZUH_AUTH_PORT=8550
export TF_VAR_wazuh_auth_proxy_port="${ARMORY_WAZUH_AUTH_PORT}"  # services/wazuh/

# PostgreSQL port on the host (SSH tunnel / internal use only — not firewalled).
export ARMORY_PG_PORT=5432
export TF_VAR_postgres_port="${ARMORY_PG_PORT}"   # vault-config/ module

# OIDC callback ports — loopback only, not firewalled.
export ARMORY_OIDC_CALLBACK_PORT=8250      # Vault CLI login callback
export ARMORY_AGENT_CLI_PORT=18080         # agent-cli OIDC callback

export ARMORY_NETWORK="armory-net"
export ARMORY_BASE_DIR="/opt/armory"

# =============================================================================
# VAULT — userpass operator account
# Module: vault-config/
# =============================================================================

export TF_VAR_operator_username="operator"
export TF_VAR_operator_password="armory-demo-2026"

# =============================================================================
# VAULT — OIDC client (shared between vault-config/ and services/keycloak/)
# The two modules use different variable names for the same secret.
# =============================================================================

export TF_VAR_oidc_client_id="vault"                            # vault-config/
export TF_VAR_oidc_client_secret="armory-vault-oidc-secret-2026"       # vault-config/
export TF_VAR_vault_oidc_client_secret="${TF_VAR_oidc_client_secret}"  # services/keycloak/

export TF_VAR_keycloak_realm="armory"   # realm in OIDC discovery URL (vault-config/)

# =============================================================================
# POSTGRESQL — superuser and vault management role
# Modules: services/postgres/ and vault-config/
# vault_mgmt_* and keycloak_db_username must match in both modules.
# =============================================================================

export TF_VAR_postgres_username="postgres"                 # services/postgres/ (POSTGRES_USER)
export TF_VAR_postgres_password="postgres-demo-2026"      # services/postgres/

export TF_VAR_vault_mgmt_username="vault_mgmt"            # vault-config/ + services/postgres/
export TF_VAR_vault_mgmt_password="vault-mgmt-demo-2026"  # vault-config/ + services/postgres/

export TF_VAR_keycloak_db_username="keycloak"             # vault-config/ + services/postgres/

# Container-to-container Vault address (used by Vault Agent sidecars on armory-net).
# The hostname matches vault/ var.container_name (default: armory-vault).
export TF_VAR_vault_agent_addr="https://armory-vault:${ARMORY_VAULT_PORT}"

# Host IP passed to modules that bind published ports (webserver, keycloak, agent).
# Using a single TF_VAR_host_ip covers all three — they share the same variable name.
export TF_VAR_host_ip="${ARMORY_HOST_IP}"

# Keycloak host port — unique variable name, safe to set globally.
export TF_VAR_keycloak_port="${ARMORY_KEYCLOAK_PORT}"

# =============================================================================
# KEYCLOAK — admin bootstrap account (stored in Vault KV v2)
# Module: vault-config/
# =============================================================================

export TF_VAR_keycloak_admin_username="admin"
export TF_VAR_keycloak_admin_password="armory-demo-2026"

# =============================================================================
# KEYCLOAK — realm operator user (seeded in the Keycloak realm import)
# Module: services/keycloak/
# =============================================================================

export TF_VAR_realm_operator_username="operator"
export TF_VAR_realm_operator_password="armory-demo-2026"

# =============================================================================
# WAZUH — Keycloak OIDC integration
# Module: services/wazuh/
# =============================================================================

export TF_VAR_keycloak_oidc_client_id="wazuh-dashboard"
export TF_VAR_required_group="wazuh-operators"

# =============================================================================
# DERIVED — do not edit; computed from values above
# =============================================================================

# Vault API address used by tofu modules that accept vault_addr.
export TF_VAR_vault_addr="https://${ARMORY_HOST_IP}:${ARMORY_VAULT_PORT}"
export ARMORY_VAULT_ADDR="${TF_VAR_vault_addr}"

# Used by tofu modules that accept armory_base_dir.
export TF_VAR_armory_base_dir="${ARMORY_BASE_DIR}"

# Alias used by rebuild.sh Phase 7 (OIDC secret passed as -var flag).
export OIDC_CLIENT_SECRET="${TF_VAR_oidc_client_secret}"
