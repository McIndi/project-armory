# Armory2 environment template for Ansible CLI runs
# Usage:
#   cp .env.example .env
#   set -a; source .env; set +a
# Verify the file was sourced:
#   test "${ARMORY_ENV_SOURCED:-}" = "armory2-env-loaded-v1"

# Sentry value used to verify .env is sourced.
ARMORY_ENV_SOURCED=armory2-env-loaded-v1

# Disable no_log redaction for sensitive tasks when deep troubleshooting is needed.
# WARNING: true will print secrets/tokens to console and logs.
# Default should remain false.
ARMORY_LOG_NOLOG=false

# Hardened Vault Secrets Operator chart coordinates (required), consumed by the
# standalone `vso` role. Must point to a forked chart that supports explicit
# kube-rbac-proxy TLS cert/key file configuration and avoids deprecated flags.
# Option A (preferred for local demo): set a local chart path and leave repo/name/version empty.
VSO_CHART_PATH=/vagrant/project-armory/charts/vso-hardened

# Option B: use a published hardened chart.
VSO_CHART_REPO=
VSO_CHART_NAME=
VSO_CHART_VERSION=

# Public ingress/domain settings consumed by multiple roles.
# Keep these values aligned with your DNS/hosts-file mappings.
ARMORY_PUBLIC_DOMAIN=armory.local
ARMORY_PUBLIC_BASE_URL=https://armory.local
ARMORY_HEADLAMP_HOST=headlamp.armory.local
ARMORY_OPENBAO_HOST=openbao.armory.local

# Optional extra SAN hostnames appended to the consolidated edge certificate.
# Leave empty for Armory-only deploys. Garrison sets this before invoking Armory.
ARMORY_EDGE_EXTRA_SAN_HOSTS=

# Optional deterministic edge-IP overrides for multi-NIC/NAT environments.
# If ARMORY_EDGE_GATEWAY_IP is set, it wins.
# Otherwise ARMORY_EDGE_GATEWAY_INTERFACE selects the interface to bind/probe.
ARMORY_EDGE_GATEWAY_IP=
ARMORY_EDGE_GATEWAY_INTERFACE=

# Additional internal DNS suffixes allowed by OpenBao PKI role for service certs.
ARMORY_INTERNAL_PKI_ALLOWED_DOMAINS=svc.cluster.local

# Project root used to derive all other repo-local paths.
# If your VM mount path changes, update this single value.
ARMORY_PROJECT_ROOT=/vagrant/project-armory

# Ansible project root for this repo's execution model.
ARMORY_ANSIBLE_ROOT=${ARMORY_PROJECT_ROOT}/ansible

# Core project settings (migrated from ansible/ansible.cfg)
ANSIBLE_INVENTORY=inventories/development/hosts.yml
ANSIBLE_ROLES_PATH=roles
ANSIBLE_HOST_KEY_CHECKING=False
ANSIBLE_RETRY_FILES_ENABLED=False
ANSIBLE_PYTHON_INTERPRETER=auto_silent
ANSIBLE_LOG_PATH=${ARMORY_PROJECT_ROOT}/log/ansible.log
ANSIBLE_DISPLAY_ARGS_TO_STDOUT=True
ANSIBLE_LOAD_CALLBACK_PLUGINS=True
ANSIBLE_CALLBACKS_ENABLED=timer
ANSIBLE_BECOME=True
ANSIBLE_BECOME_METHOD=sudo
ANSIBLE_BECOME_ASK_PASS=False

# Useful runtime defaults (explicit for predictability)
# Docs default: default
ANSIBLE_STDOUT_CALLBACK=default
# Docs default: 5
ANSIBLE_FORKS=5
# Docs default: 10. Raised: the single-VM stack runs at high load during/after
# deploys and the sudo (become) handshake intermittently exceeds 10s, failing
# tasks with "Timed out waiting for become success".
ANSIBLE_TIMEOUT=60
# Docs default: 0
ANSIBLE_VERBOSITY=0
# Docs default: True
ANSIBLE_DEPRECATION_WARNINGS=True
# Docs default: True
ANSIBLE_SYSTEM_WARNINGS=True
# Docs default: True
ANSIBLE_INVENTORY_UNPARSED_WARNING=True
# Docs default: warning
ANSIBLE_HOST_PATTERN_MISMATCH=warning
# Docs default: implicit
ANSIBLE_GATHERING=implicit
# Docs default: False
ANSIBLE_PIPELINING=False
# Docs default: False
ANSIBLE_DIFF_ALWAYS=False
# Docs default: 3
ANSIBLE_DIFF_CONTEXT=3
# Docs default: False
ANSIBLE_FORCE_COLOR=False
# Docs default: False
ANSIBLE_NOCOLOR=False

# Collections and role install behavior
# Docs default: warning
ANSIBLE_COLLECTIONS_ON_ANSIBLE_VERSION_MISMATCH=warning
# Docs default: True
ANSIBLE_COLLECTIONS_SCAN_SYS_PATH=True
# Optional override. Leave commented to use Ansible default path resolution.
# ANSIBLE_COLLECTIONS_PATH=/home/vagrant/.ansible/collections:/usr/share/ansible/collections

# Optional vault settings (leave commented unless needed)
# Docs default: False
# ANSIBLE_ASK_VAULT_PASS=False
# Docs default: unset
# ANSIBLE_VAULT_PASSWORD_FILE=${ARMORY_ANSIBLE_ROOT}/.vault_pass
# Docs default: []
# ANSIBLE_VAULT_IDENTITY_LIST=dev@${ARMORY_ANSIBLE_ROOT}/.vault_pass

# Optional tags defaults (can be overridden by CLI flags)
# Docs default: []
# ANSIBLE_RUN_TAGS=
# Docs default: []
# ANSIBLE_SKIP_TAGS=

# --- Delve app image (local build; no registry) ------------------------------
# Defaults build localhost/delve-armory on-node and import into k3s containerd.
# Repo name containing "delve-armory" auto-enables the armory_dashboard app.
#ARMORY_DELVE_IMAGE_REPOSITORY=localhost/delve-armory
#ARMORY_DELVE_IMAGE_TAG=v0.1.0
#ARMORY_DELVE_IMAGE_PULL_POLICY=IfNotPresent
# Pin the upstream base before a demo (resolve a real ghcr.io/mcindi/delve tag/digest).
#ARMORY_DELVE_BASE_TAG=latest
# Force a rebuild+reimport even if the tag is already present on-node.
#ARMORY_DELVE_IMAGE_REBUILD=false
