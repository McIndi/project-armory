# Armory2 environment template for Ansible CLI runs
# Usage:
#   cp .env.example .env
#   set -a; source .env; set +a
# Verify the file was sourced:
#   test "${ARMORY_ENV_SOURCED:-}" = "armory2-env-loaded-v1"

# Sentry value used to verify .env is sourced.
ARMORY_ENV_SOURCED=armory2-env-loaded-v1

# Enable human-readable companion debug summaries from roles.
# Accepted truthy values include: true, True, yes, 1, on.
# Default should remain false for normal runs.
ARMORY_BUILD_DEBUG=false

# Disable no_log redaction for sensitive tasks when deep troubleshooting is needed.
# WARNING: true will print secrets/tokens to console and logs.
# Default should remain false.
ARMORY_LOG_NOLOG=false

# Seeded BeeAI/Keycloak admin email used by beeai_agentstack_tofu role.
# Must be a non-reserved domain accepted by email validators.
BEEAI_ADMIN_EMAIL=admin@armory.dev

# Ansible project root for this repo's execution model.
# Commands are expected to run from /vagrant/ansible.
ARMORY_ANSIBLE_ROOT=/vagrant/ansible

# Core project settings (migrated from ansible/ansible.cfg)
ANSIBLE_INVENTORY=inventories/development/hosts.yml
ANSIBLE_ROLES_PATH=roles
ANSIBLE_HOST_KEY_CHECKING=False
ANSIBLE_RETRY_FILES_ENABLED=False
ANSIBLE_PYTHON_INTERPRETER=auto_silent
ANSIBLE_LOG_PATH=/vagrant/log/ansible.log
ANSIBLE_DISPLAY_ARGS_TO_STDOUT=True
ANSIBLE_LOAD_CALLBACK_PLUGINS=True
ANSIBLE_CALLBACKS_ENABLED=timer
ANSIBLE_BECOME=True
ANSIBLE_BECOME_METHOD=sudo
ANSIBLE_BECOME_ASK_PASS=False

# Useful runtime defaults (explicit for predictability)
# Docs default: default
ANSIBLE_STDOUT_CALLBACK=default
# Docs default: 5
ANSIBLE_FORKS=5
# Docs default: 10
ANSIBLE_TIMEOUT=10
# Docs default: 0
ANSIBLE_VERBOSITY=0
# Docs default: True
ANSIBLE_DEPRECATION_WARNINGS=True
# Docs default: True
ANSIBLE_SYSTEM_WARNINGS=True
# Docs default: True
ANSIBLE_INVENTORY_UNPARSED_WARNING=True
# Docs default: warning
ANSIBLE_HOST_PATTERN_MISMATCH=warning
# Docs default: implicit
ANSIBLE_GATHERING=implicit
# Docs default: False
ANSIBLE_PIPELINING=False
# Docs default: False
ANSIBLE_DIFF_ALWAYS=False
# Docs default: 3
ANSIBLE_DIFF_CONTEXT=3
# Docs default: False
ANSIBLE_FORCE_COLOR=False
# Docs default: False
ANSIBLE_NOCOLOR=False

# Collections and role install behavior
# Docs default: warning
ANSIBLE_COLLECTIONS_ON_ANSIBLE_VERSION_MISMATCH=warning
# Docs default: True
ANSIBLE_COLLECTIONS_SCAN_SYS_PATH=True
# Optional override. Leave commented to use Ansible default path resolution.
# ANSIBLE_COLLECTIONS_PATH=/home/vagrant/.ansible/collections:/usr/share/ansible/collections

# Optional vault settings (leave commented unless needed)
# Docs default: False
# ANSIBLE_ASK_VAULT_PASS=False
# Docs default: unset
# ANSIBLE_VAULT_PASSWORD_FILE=/vagrant/ansible/.vault_pass
# Docs default: []
# ANSIBLE_VAULT_IDENTITY_LIST=dev@/vagrant/ansible/.vault_pass

# Optional tags defaults (can be overridden by CLI flags)
# Docs default: []
# ANSIBLE_RUN_TAGS=
# Docs default: []
# ANSIBLE_SKIP_TAGS=
