# ===========================================================================
# Vault Agent configuration — Wazuh sidecar
# Generated by OpenTofu — do not edit by hand.
# ===========================================================================

vault {
  address     = "${vault_addr}"
  tls_ca_cert = "/vault/tls/ca.crt"
}

auto_auth {
  method "approle" {
    mount_path = "auth/${approle_mount_path}"

    config {
      role_id_file_path                   = "/vault/approle/role_id"
      secret_id_file_path                 = "/vault/approle/wrapped_secret_id"
      secret_id_response_wrapping_path    = "auth/${approle_mount_path}/role/wazuh/secret-id"
      remove_secret_id_file_after_reading = true
    }
  }
}

template {
  contents = <<EOT
{{- with pkiCert "${pki_ext_mount}/issue/${pki_ext_role}" "common_name=${server_name}" "ttl=${cert_ttl}" "ip_sans=${ip_sans_str}"%{ if alt_names_str != "" } "alt_names=${alt_names_str}"%{ endif } -}}
{{ .Cert }}{{ .CA }}{{ .Key }}
{{- end }}
EOT
  destination = "/vault/certs/wazuh.pem"
  perms       = "0644"
}

template {
  contents = <<EOT
{{- with secret "${oidc_kv_path}" -}}
OAUTH2_PROXY_CLIENT_SECRET={{ .Data.data.client_secret }}
OAUTH2_PROXY_COOKIE_SECRET={{ .Data.data.cookie_secret }}
{{- end }}
EOT
  destination = "/vault/secrets/oidc.env"
  perms       = "0644"
}
